# Exemplo de variáveis para Supabase local (Nuxt)
# Copie para `.env` e preencha com seus valores locais

SUPABASE_URL=http://localhost:54321
# Publishable key (v2): pegue com `supabase status`
SUPABASE_KEY=your_publishable_key_local
# Secret key (v2): pegue com `supabase status`
SUPABASE_SECRET_KEY=your_secret_key_local